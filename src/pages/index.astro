---
import Header from "@/components/Header.astro";
import { URL_BASE } from "@/config";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <div
    class="min-h-screen flex flex-col bg-right lg:bg-center lg:bg-cover"
    style={`background-image: url(${URL_BASE}/backgrounds/bg_home.webp);`}
  >
    <Header />
    <main
      class="w-7xl mx-auto max-w-full p-4 md:p-6 flex-1 flex flex-col lg:flex-row h-full"
    >
      <div class="w-full lg:w-1/2 flex flex-col items-start">
        <h1 class="text-4xl lg:text-6xl font-bold text-black mb-2 ">
          <span class="px-6 lg:px-10 py-2">CASOS</span>
          <span class="block text-white bg-linear-(--gradient-btn) px-6 lg:px-10 py-2 rounded-full" style="font-size:1.15em;"
            >DAYAMINERAL</span
          >
        </h1>
        <p class="mt-8 text-2xl xs:text-3xl text-black px-6 lg:px-10 py-2">
          Seleccione en cada caso el beneficio que aporta Dayamineral.
        </p>
        
      </div>
      <div class="w-full lg:w-1/2 flex flex-col items-end justify-end flex-1">
        <div class="flex">
          <a
            class="text-2xl lg:text-3xl text-white font-bold py-3 px-6 rounded-full flex items-center bg-linear-(--gradient-btn) hover:scale-105 transition-transform duration-300"
            href={`${URL_BASE}/quiz`}
          >
            COMENZAR
            <img
              class="w-auto h-10 ml-4"
              src={`${URL_BASE}/iconos/arrow.webp`}
              alt="Arrow Right"
            />
          </a>
        </div>
      </div>
    </main>
  </div>
</Layout>
